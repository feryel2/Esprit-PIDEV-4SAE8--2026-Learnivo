pipeline {
    agent any

    environment {
        SONAR_PROJECT_KEY = 'frontend'
        SONAR_PROJECT_NAME = 'Frontend'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('frontend') {
                    sh 'npm install'
                }
            }
        }

        stage('Build') {
            steps {
                dir('frontend') {
                    sh 'npm run build'
                }
            }
        }

        stage('Test') {
            steps {
                dir('frontend') {
                    sh 'npm run test -- --watch=false'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar') {
                    dir('frontend') {
                        sh '''
                            export PATH=$PATH:/opt/sonar-scanner/bin

                            sonar-scanner \
                              -Dsonar.projectKey=frontend \
                              -Dsonar.projectName=Frontend \
                              -Dsonar.sources=src \
                              -Dsonar.host.url=http://localhost:9000
                        '''
                    }
                }
            }
        }
    }

    post {
        success {
            script {
                try {
                    build job: 'frontend-cd', wait: false, propagate: false
                } catch (err) {
                    echo "frontend-cd job not found, skipping CD step"
                }
            }
        }

        failure {
            echo 'Pipeline failed ❌'
        }
    }
}
