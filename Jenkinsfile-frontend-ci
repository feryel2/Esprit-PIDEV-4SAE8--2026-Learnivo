pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Skip Tests') {
            steps {
                echo 'Tests skipped for demo'
            }
        }

        stage('SonarQube') {
            steps {
                dir('frontend') {
                    withSonarQubeEnv('sonariyadh') {
                        sh '''
                            npx sonar-scanner \
                            -Dsonar.projectKey=learnivo-frontend \
                            -Dsonar.projectName="Learnivo Frontend" \
                            -Dsonar.sources=src/main.ts \
                            -Dsonar.host.url=http://localhost:9000
                        '''
                    }
                }
            }
        }
    }
}