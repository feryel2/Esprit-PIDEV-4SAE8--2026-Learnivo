pipeline {
    agent any

    environment {
        SONAR_PROJECT_KEY = 'learnivo-frontend'
        SONAR_PROJECT_NAME = 'Learnivo Frontend'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Check Node Version') {
            steps {
                sh '''
                    node -v
                    npm -v
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('frontend') {
                    sh 'npm install'
                }
            }
        }

        stage('Lint & Test') {
            steps {
                dir('frontend') {
                    echo 'Skipping tests for now'
                    // sh 'npm run test -- --watch=false --browsers=ChromeHeadless'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('frontend') {
                    withSonarQubeEnv('sonariyadh') {
                        sh '''
                            sonar-scanner \
                            -Dsonar.projectKey=learnivo-frontend \
                            -Dsonar.projectName="Learnivo Frontend" \
                            -Dsonar.sources=src \
                            -Dsonar.host.url=http://localhost:9000
                        '''
                    }
                }
            }
        }
    }

    post {
        success {
            build job: 'iyadh-frontend-cd', wait: false
        }
    }
}