pipeline {
    agent any

    tools {
        maven 'Maven 3.x'
        jdk 'JDK 17'
    }

    environment {
        SONAR_PROJECT_KEY = 'class-service'
        SONAR_PROJECT_NAME = 'Class Service'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                dir('backend/class-service') {
                    sh 'mvn clean compile -DskipTests'
                }
            }
        }

        stage('Test') {
            steps {
                dir('backend/class-service') {
                    sh 'mvn test'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQubeServer') {
                    dir('backend/class-service') {
                        sh """
                            mvn sonar:sonar \
                            -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                            -Dsonar.projectName='${SONAR_PROJECT_NAME}'
                        """
                    }
                }
            }
        }
    }

    post {
        always {
            junit 'backend/class-service/target/surefire-reports/*.xml'
        }
        success {
            echo 'Class Service pipeline completed successfully!'
        }
        failure {
            echo 'Class Service pipeline failed.'
        }
    }
}
