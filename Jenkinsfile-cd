pipeline {
    agent any

    environment {
        IMAGE_NAME = 'bessem785/learnivo-frontend'
        DOCKER_CREDS_ID = 'iyadhdocker'
        KUBECONFIG = "/var/lib/jenkins/.kube/config"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Check Node') {
            steps {
                dir('frontend') {
                    sh '''
                        node -v
                        npm -v
                    '''
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('frontend') {
                    sh '''
                        npm install
                        npm install @tailwindcss/oxide-linux-x64-gnu --save-dev
                    '''
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir('frontend') {
                    sh '''
                        npm run build -- --configuration development
                    '''
                }
            }
        }

        stage('Docker Login & Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "${DOCKER_CREDS_ID}",
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                        echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin

                        docker build --no-cache -t $IMAGE_NAME:latest ./frontend

                        docker push $IMAGE_NAME:latest
                    '''
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh '''
                    kubectl apply -f frontend/k8s/deployment.yaml
                '''
            }
        }
    }

    post {
        success {
            echo 'Frontend Deployment Pipeline SUCCESS 🚀'
        }

        failure {
            echo 'Frontend Deployment Pipeline FAILED ❌'
        }

        always {
            sh 'docker logout || true'
        }
    }
}