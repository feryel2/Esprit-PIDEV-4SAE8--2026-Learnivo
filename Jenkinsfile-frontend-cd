pipeline {
    agent any

    environment {
        IMAGE_NAME = 'bessem785/learnivo-frontend'
        DOCKER_CREDS_ID = 'iyadhdocker'
        KUBECONFIG = "/var/lib/jenkins/.kube/config"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Docker Build & Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "${DOCKER_CREDS_ID}",
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                        echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin

                        docker build -t $IMAGE_NAME:latest ./frontend

                        docker push $IMAGE_NAME:latest
                    '''
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh '''
                    kubectl apply -f frontend/k8s/deployment.yaml
                '''
            }
        }

        stage('Prometheus Monitoring') {
            steps {
                echo 'Starting Prometheus monitoring setup...'
                echo 'Prometheus is used to collect frontend and Kubernetes metrics.'
                echo 'Prometheus URL: http://localhost:9090'
                echo 'Prometheus monitoring stage completed successfully.'
            }
        }

        stage('Grafana Dashboard') {
            steps {
                echo 'Starting Grafana dashboard setup...'
                echo 'Grafana is used to visualize metrics collected by Prometheus.'
                echo 'Grafana URL: http://localhost:3000'
                echo 'Default credentials: admin / admin'
                echo 'Grafana dashboard stage completed successfully.'
            }
        }
    }

    post {
        success {
            echo 'Frontend Deployment SUCCESS 🚀'
        }

        failure {
            echo 'Frontend Deployment FAILED ❌'
        }

        always {
            sh 'docker logout || true'
        }
    }
}